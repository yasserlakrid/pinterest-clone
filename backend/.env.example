# Email Configuration
# Utilisé pour envoyer les réponses d'agents aux clients

# SMTP Server (Gmail, Outlook, custom SMTP server, etc.)
SMTP_SERVER=smtp.gmail.com

# SMTP Port (587 for TLS, 465 for SSL)
SMTP_PORT=587

# Sender Email Address
SENDER_EMAIL=your-email@gmail.com

# Sender Email Password or App Password
# Pour Gmail: utiliser un "App Password" (pas le mot de passe principal)
# Voir: https://support.google.com/accounts/answer/185833
SENDER_PASSWORD=your-app-password

# Database URL (optionnel)
DATABASE_URL=sqlite:///./database.db

# Reset tables on startup for local development only
RESET_DB_ON_STARTUP=false

# Comma-separated production frontend origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
